# This .gitignore file should be placed at the
# root of your Unity project directory

.utmp/

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

*.log
*.out

# ==========================================
# Blender
# ==========================================

*.blend1
*.blend1.meta

# ==========================================
# Memory / Recordings
# ==========================================

/[Mm]emoryCaptures/
/[Rr]ecordings/

# ==========================================
# Asset Store Tools
# ==========================================

# Uncomment if needed
# /[Aa]ssets/AssetStoreTools*

# ==========================================
# JetBrains Rider
# ==========================================

/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/
.consulo/

# ==========================================
# Visual Studio / VSCode
# ==========================================

.vs/

# VSCode workspace settings
.vscode/*

# Keep shared workspace recommendations/settings
!.vscode/extensions.json
!.vscode/settings.json

# ==========================================
# Gradle
# ==========================================

.gradle/

# ==========================================
# Autogenerated Solution / Project Files
# ==========================================

ExportedObj/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ==========================================
# Unity Generated Meta Files
# ==========================================

*.pidb.meta
*.pdb.meta
*.mdb.meta

# ==========================================
# Crash Reports
# ==========================================

sysinfo.txt
mono_crash.*
crashlytics-build.properties

# ==========================================
# Unity Builds
# ==========================================

*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# ==========================================
# Test Runner
# ==========================================

InitTestScene*.unity*

# ==========================================
# Addressables
# ==========================================

/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*

# Addressables content state files
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# ==========================================
# Unity Visual Scripting
# ==========================================

/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# ==========================================
# Auto-generated Test Scenes
# ==========================================

/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# ==========================================
# Docker
# ==========================================

docker-compose.override.yml

# ==========================================
# Environment Variables
# ==========================================

.env
.env.*

# ==========================================
# Dedicated Server Runtime Data
# ==========================================

DedicatedServerData/

# ==========================================
# Optional Backend Runtime Data
# ==========================================

# Uncomment if you generate runtime databases
# *.db
# *.sqlite
# *.sqlite3

# ==========================================
# Optional CI/CD
# ==========================================

# Uncomment if needed later
# coverage/
# artifacts/
# test-results/

MirrorExamplesPipelineConverted.txt