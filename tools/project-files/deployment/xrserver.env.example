# XRServer environment configuration.
# CXR_PUBLIC_ADDRESS must be the server's EXTERNAL / routable IP
# that clients can reach. Run `ip addr show | grep "inet "` to list all interfaces.

CXR_PUBLIC_ADDRESS=192.168.1.50
CXR_REGISTRY_URL=http://127.0.0.1:8080
CXR_HOST_MANAGER_PORT=3000
CXR_REGISTRY_PORT=8080
CXR_REGISTRY_STALE_MS=90000
CXR_ROOM_PORT_START=7777
CXR_ROOM_PORT_END=7900
# CXR_UNITY_BUILDS_DIRECTORY=/home/ashis/XRServer2/unity-builds
CXR_LOGS_DIRECTORY=/home/ashis/XRServer2/host-manager/logs
# CXR_ADMIN_TOKEN=replace-me
